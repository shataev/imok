# API
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars

# Database (Supabase — use Transaction Pooler URL for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Redis (Upstash — use rediss:// for production)
REDIS_URL=redis://localhost:6379

# Firebase FCM
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+18449565797
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_FROM_EMAIL=noreply@imok.app

# Mobile (apps/mobile/.env)
# EXPO_PUBLIC_API_URL=https://imokapi-production.up.railway.app
